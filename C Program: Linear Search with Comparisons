#include <stdio.h>

int main() {
    int arr[100], n, i, k;
    int comparisons = 0;
    int found = 0;

    // Input size
    scanf("%d", &n);

    // Input array elements
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Input key
    scanf("%d", &k);

    // Linear search
    for(i = 0; i < n; i++) {
        comparisons++;
        if(arr[i] == k) {
            printf("Found at index %d\n", i);
            found = 1;
            break;
        }
    }

    if(!found) {
        printf("Not Found\n");
    }

    // Print comparisons
    printf("Comparisons = %d", comparisons);

    return 0;
}

#include <stdio.h>

#define MAX 100

int stack[MAX];
int top = -1;

// Push operation
void push(int x) {
    stack[++top] = x;
}

// Pop operation
void pop() {
    if(top != -1)
        top--;
}

// Display stack
void display() {
    for(int i = top; i >= 0; i--) {
        printf("%d ", stack[i]);
    }
}

int main() {
    int n;
    scanf("%d", &n);

    // Push elements
    for(int i = 0; i < n; i++) {
        int val;
        scanf("%d", &val);
        push(val);
    }

    int m;
    scanf("%d", &m);

    // Pop m elements
    for(int i = 0; i < m; i++) {
        pop();
    }

    // Display remaining stack
    display();

    return 0;
}

#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

// Node structure for stack
struct Node {
    int data;
    struct Node* next;
};

// Push
void push(struct Node** top, int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;
    newNode->next = *top;
    *top = newNode;
}

// Pop
int pop(struct Node** top) {
    if(*top == NULL) {
        printf("Stack Underflow\n");
        return 0;
    }
    struct Node* temp = *top;
    int val = temp->data;
    *top = temp->next;
    free(temp);
    return val;
}

int main() {
    char exp[100];
    struct Node* top = NULL;

    // Read entire line
    fgets(exp, sizeof(exp), stdin);

    for(int i = 0; exp[i] != '\0'; i++) {

        // Skip spaces
        if(exp[i] == ' ')
            continue;

        // If operand (digit)
        if(isdigit(exp[i])) {
            push(&top, exp[i] - '0');
        }
        // Operator
        else {
            int val2 = pop(&top);
            int val1 = pop(&top);
            int result;

            switch(exp[i]) {
                case '+': result = val1 + val2; break;
                case '-': result = val1 - val2; break;
                case '*': result = val1 * val2; break;
                case '/': result = val1 / val2; break;
            }

            push(&top, result);
        }
    }

    // Final result
    printf("%d", pop(&top));

    return 0;
}

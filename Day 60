#include <stdio.h>

int main() {
    int N;
    scanf("%d", &N);
    
    int arr[100001];  // Large enough for typical constraints
    for(int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }
    
    int isHeap = 1;
    
    // Check from last parent to root
    for(int i = (N/2) - 1; i >= 0; i--) {
        // Check left child
        if(arr[i] > arr[2*i + 1]) {
            isHeap = 0;
            break;
        }
        // Check right child if exists
        if(2*i + 2 < N && arr[i] > arr[2*i + 2]) {
            isHeap = 0;
            break;
        }
    }
    
    printf("%s\n", isHeap ? "YES" : "NO");
    return 0;
}

#include <stdio.h>

#define MAX 100

int main() {
    int matrix[MAX][MAX];
    int n, m, i, j, u, v, isDirected;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter number of edges: ");
    scanf("%d", &m);

    printf("Is the graph directed? (1 for Yes, 0 for No): ");
    scanf("%d", &isDirected);

    // 1. Initialize the matrix with 0
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            matrix[i][j] = 0;
        }
    }

    // 2. Input edges and fill the matrix
    printf("Enter %d pairs of edges (u v):\n", m);
    for (i = 0; i < m; i++) {
        scanf("%d %d", &u, &v);

        // Standard check to prevent array overflow
        if (u < n && v < n) {
            matrix[u][v] = 1;
            
            if (!isDirected) {
                matrix[v][u] = 1; // Mirror the edge for undirected
            }
        }
    }

    // 3. Output the resulting matrix
    printf("\nAdjacency Matrix:\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            printf("%d ", matrix[i][j]);
        }
        printf("\n");
    }

    return 0;
}

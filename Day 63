#include <stdio.h>
#include <stdlib.h>

struct Node {
    int vertex;
    struct Node* next;
};

// Global or passed array to track visited vertices
int visited[100]; 

void DFS(struct Node* adjList[], int s) {
    // 1. Mark the current node as visited
    visited[s] = 1;
    printf("%d ", s);

    // 2. Traverse all adjacent vertices
    struct Node* temp = adjList[s];
    while (temp != NULL) {
        int connectedVertex = temp->vertex;
        
        // 3. If the neighbor hasn't been visited, recurse
        if (visited[connectedVertex] == 0) {
            DFS(adjList, connectedVertex);
        }
        temp = temp->next;
    }
}

// Helper to add edges to adjacency list
void addEdge(struct Node* adjList[], int u, int v) {
    struct Node* newNode = malloc(sizeof(struct Node));
    newNode->vertex = v;
    newNode->next = adjList[u];
    adjList[u] = newNode;
}

int main() {
    int n, m, s, u, v;

    printf("Enter number of vertices and edges: ");
    scanf("%d %d", &n, &m);

    struct Node* adjList[n];
    for (int i = 0; i < n; i++) {
        adjList[i] = NULL;
        visited[i] = 0;
    }

    printf("Enter %d edges (u v):\n", m);
    for (int i = 0; i < m; i++) {
        scanf("%d %d", &u, &v);
        addEdge(adjList, u, v);
        addEdge(adjList, v, u); // Assuming undirected for this example
    }

    printf("Enter starting vertex: ");
    scanf("%d", &s);

    printf("DFS Traversal Order: ");
    DFS(adjList, s);
    printf("\n");

    return 0;
}

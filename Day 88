#include <stdio.h>

// Function to sort array
void sort(int arr[], int n) {
    int i, j, temp;

    for(i = 0; i < n - 1; i++) {
        for(j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

// Function to check if cows can be placed
int canPlaceCows(int stalls[], int n, int k, int minDist) {
    int count = 1;
    int lastPos = stalls[0];

    for(int i = 1; i < n; i++) {
        if(stalls[i] - lastPos >= minDist) {
            count++;
            lastPos = stalls[i];
        }

        if(count == k)
            return 1;
    }

    return 0;
}

int main() {
    int n, k;

    scanf("%d %d", &n, &k);

    int stalls[n];

    for(int i = 0; i < n; i++) {
        scanf("%d", &stalls[i]);
    }

    // Sort stall positions
    sort(stalls, n);

    int low = 1;
    int high = stalls[n - 1] - stalls[0];
    int answer = 0;

    // Binary Search
    while(low <= high) {
        int mid = (low + high) / 2;

        if(canPlaceCows(stalls, n, k, mid)) {
            answer = mid;
            low = mid + 1;
        }
        else {
            high = mid - 1;
        }
    }

    printf("%d\n", answer);

    return 0;
}

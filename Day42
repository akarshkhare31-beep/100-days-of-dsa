#include <stdio.h>

#define MAX 100

// Queue
int queue[MAX];
int front = 0, rear = -1;

// Stack
int stack[MAX];
int top = -1;

// Enqueue
void enqueue(int x) {
    queue[++rear] = x;
}

// Dequeue
int dequeue() {
    return queue[front++];
}

// Push (stack)
void push(int x) {
    stack[++top] = x;
}

// Pop (stack)
int pop() {
    return stack[top--];
}

// Check if queue is empty
int isQueueEmpty() {
    return (front > rear);
}

// Check if stack is empty
int isStackEmpty() {
    return (top == -1);
}

int main() {
    int N, x;

    scanf("%d", &N);

    // Input queue
    for (int i = 0; i < N; i++) {
        scanf("%d", &x);
        enqueue(x);
    }

    // Step 1: Queue → Stack
    while (!isQueueEmpty()) {
        push(dequeue());
    }

    // Step 2: Stack → Queue
    while (!isStackEmpty()) {
        enqueue(pop());
    }

    // Print reversed queue
    for (int i = front; i <= rear; i++) {
        printf("%d ", queue[i]);
    }

    return 0;
}
